# --- Database (required) ----------------------------------------------------
# Matches docker-compose.yml (docker compose up -d) — host port 5544
DATABASE_URL=postgresql://tca:tca@localhost:5544/tca

# --- LLM provider selection -------------------------------------------------
# cortex = Gemini via the Cortex OpenAI-compatible gateway (native tool calling)
# claude = Claude via the Claude Agent SDK (Claude Code auth, prompted tools)
LLM_PROVIDER=cortex

# --- Cortex (when LLM_PROVIDER=cortex) --------------------------------------
CORTEX_API_KEY=your-gateway-key
CORTEX_BASE_URL=https://your-cortex-gateway/v1
CORTEX_MODEL=gemini-2.5-flash

# --- Claude (when LLM_PROVIDER=claude) --------------------------------------
# No API key needed — uses the logged-in Claude Code CLI.
CLAUDE_MODEL=claude-sonnet-4-6

# --- SMS notifications (optional) -------------------------------------------
# If unset, notifications are logged instead of sent (app still runs).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Route ALL SMS to one number (demo / Twilio trial verified number)
NOTIFY_OVERRIDE_PHONE=
